# 1. Bearer token from browser DevTools (see README for how to get it)
BEARER_TOKEN=eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9...

# 2. (Optional) Your contractor ID from 10x — if empty, extracted from token automatically
CONTRACTOR_ID=

# 3. Notion integration token (from notion.so/my-integrations)
NOTION_TOKEN=secret_...

# 4. Notion page ID to create the database inside (copy from page URL)
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 5. Filled automatically after running setup_notion.py
NOTION_DATABASE_ID=
